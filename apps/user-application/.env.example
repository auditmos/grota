# Database (Neon Postgres)
DATABASE_HOST=ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_USERNAME=neondb_owner
DATABASE_PASSWORD=npg_xxx

# Better Auth
BETTER_AUTH_SECRET=your-secret-key
BETTER_AUTH_BASE_URL=http://localhost:3000

# Environment
CLOUDFLARE_ENV=dev

# Data Service (public URL for browser)
VITE_DATA_SERVICE_URL=http://localhost:8788
VITE_API_TOKEN=your-api-token

# Data Service (server-side binding token)
DATA_SERVICE_API_TOKEN=your-api-token

# Google OAuth - required from doc 004
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
