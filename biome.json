{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"formatter": {
		"indentStyle": "tab",
		"lineWidth": 100,
		"attributePosition": "auto"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"trailingCommas": "all",
			"semicolons": "always"
		}
	},
	"css": {
		"parser": {
			"cssModules": false,
			"tailwindDirectives": true
		},
		"formatter": {
			"enabled": false
		},
		"linter": {
			"enabled": false
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"a11y": {
				"useHtmlLang": "warn",
				"noLabelWithoutControl": {
					"level": "warn",
					"options": {
						"inputComponents": ["Input", "Textarea", "Select"]
					}
				},
				"noRedundantRoles": "warn",
				"useSemanticElements": "warn"
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": "warn"
			},
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "warn",
				"noUnusedFunctionParameters": "warn",
				"useImportExtensions": "off"
			},
			"style": {
				"noDefaultExport": "off",
				"useImportType": "error",
				"useNodejsImportProtocol": "error",
				"noNonNullAssertion": "warn"
			},
			"suspicious": {
				"noExplicitAny": "error",
				"noConsole": "warn"
			}
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!**/.cache",
			"!**/*.tsbuildinfo",
			"!**/worker-configuration.d.ts",
			"!**/routeTree.gen.ts",
			"!packages/data-ops/src/drizzle/migrations",
			"!packages/data-ops/src/drizzle/auth-schema.ts",
			"!**/.wrangler",
			"!configs"
		]
	},
	"overrides": [
		{
			"includes": ["packages/data-ops/src/database/seed/**", "packages/data-ops/config/**"],
			"linter": {
				"rules": {
					"suspicious": { "noConsole": "off" },
					"style": { "noNonNullAssertion": "off" }
				}
			}
		}
	],
	"plugins": [
		"./plugins/no-raw-throw.grit",
		"./plugins/no-then-chains.grit",
		"./plugins/no-ts-ignore.grit",
		"./plugins/no-as-any.grit",
		"./plugins/no-todo-comments.grit"
	]
}
